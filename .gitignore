# Ignore local config with secrets
*.conf
!etc/hetzner_ddns.conf.example

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Build artifacts
build/
dist/
*.sbom.json

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Coverage
.coverage
.coverage.*
coverage.xml
htmlcov/

# Logs
*.log

# Systemd runtime junk (not in repo)
*.service~
*.timer~

# OS files
.DS_Store
Thumbs.db

# Editor swaps (Vim!)
*.swp
*.swo
*.swn

# Per-user Claude Code overrides (not shared)
.claude/settings.local.json
